{
  "name": "dev-autopilot",
  "version": "0.2.0",
  "description": "Agent-agnostic unattended development orchestrator. Plan → Execute → Review.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "devap": "dist/index.js",
    "dev-autopilot": "dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist",
    "test": "vitest run --passWithNoTests",
    "prepublishOnly": "node scripts/copy-skills.js"
  },
  "keywords": [
    "devap",
    "orchestrator",
    "ai-agent",
    "claude",
    "opencode",
    "automation",
    "dag",
    "task-runner",
    "unattended"
  ],
  "author": "AsiaOstrich",
  "homepage": "https://github.com/AsiaOstrich/dev-autopilot#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/AsiaOstrich/dev-autopilot.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/AsiaOstrich/dev-autopilot/issues"
  },
  "files": [
    "dist",
    "skills",
    "recipes"
  ],
  "dependencies": {
    "commander": "^13.0.0",
    "js-yaml": "^4.1.1"
  },
  "optionalDependencies": {
    "@asiaostrich/telemetry-client": "file:../../../asiaostrich-telemetry-client"
  },
  "devDependencies": {
    "@devap/adapter-claude": "workspace:*",
    "@devap/adapter-cli": "workspace:*",
    "@devap/adapter-opencode": "workspace:*",
    "@devap/core": "workspace:*",
    "@types/js-yaml": "^4.0.9",
    "tsup": "^8.5.1",
    "typescript": "^5.6.0",
    "vitest": "^2.0.0"
  },
  "license": "MIT"
}
