{
  "name": "dev-autopilot",
  "version": "0.1.1",
  "description": "Agent-agnostic unattended development orchestrator. Plan → Execute → Review.",
  "type": "module",
  "bin": {
    "devap": "dist/index.js",
    "dev-autopilot": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "test": "vitest run --passWithNoTests"
  },
  "keywords": [
    "devap",
    "orchestrator",
    "ai-agent",
    "claude",
    "opencode",
    "automation",
    "dag",
    "task-runner",
    "unattended"
  ],
  "author": "AsiaOstrich",
  "homepage": "https://github.com/AsiaOstrich/dev-autopilot#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/AsiaOstrich/dev-autopilot.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/AsiaOstrich/dev-autopilot/issues"
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@devap/core": "workspace:*",
    "@devap/adapter-claude": "workspace:*",
    "@devap/adapter-opencode": "workspace:*",
    "@devap/adapter-cli": "workspace:*",
    "commander": "^13.0.0"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "vitest": "^2.0.0"
  },
  "license": "Apache-2.0"
}
